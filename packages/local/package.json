{
  "name": "@lucas-barake/effect-local",
  "version": "0.2.0",
  "description": "Local-first domain primitives for Effect",
  "homepage": "https://github.com/lucas-barake/effect-local#readme",
  "bugs": "https://github.com/lucas-barake/effect-local/issues",
  "keywords": [
    "effect",
    "local-first",
    "automerge",
    "offline-first",
    "typescript"
  ],
  "engines": {
    "node": "^22.22.2 || ^24.15.0 || >=26.0.0"
  },
  "type": "module",
  "license": "MIT",
  "sideEffects": [],
  "repository": {
    "type": "git",
    "url": "https://github.com/lucas-barake/effect-local.git",
    "directory": "packages/local"
  },
  "exports": {
    "./package.json": "./package.json",
    ".": "./src/index.ts",
    "./*": "./src/*.ts",
    "./internal/*": null
  },
  "publishConfig": {
    "access": "public",
    "provenance": true,
    "exports": {
      "./package.json": "./package.json",
      ".": "./dist/index.js",
      "./*": "./dist/*.js",
      "./internal/*": null
    }
  },
  "files": [
    "README.md",
    "LICENSE",
    "src/**/*.ts",
    "dist/**/*.js",
    "dist/**/*.js.map",
    "dist/**/*.d.ts",
    "dist/**/*.d.ts.map"
  ],
  "scripts": {
    "build": "tsc -b tsconfig.json",
    "build:tsgo": "tsgo -b tsconfig.json",
    "check": "tsc -b tsconfig.json",
    "test": "vitest --config vitest.config.ts"
  },
  "peerDependencies": {
    "@automerge/automerge": "^3.3.2",
    "effect": ">=4.0.0-beta.99 <4.0.1"
  },
  "devDependencies": {
    "@automerge/automerge": "3.3.2",
    "@effect/platform-node": "4.0.0-beta.99",
    "effect": "4.0.0-beta.99"
  }
}
