{
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.18.1",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "clean": "node scripts/clean.mjs",
    "bench": "vitest bench --run",
    "build": "tsc -b tsconfig.packages.json",
    "build:tsgo": "tsgo -b tsconfig.packages.json",
    "circular": "madge --extensions ts --circular --no-color --no-spinner packages/*/src",
    "dead-code": "knip --no-config-hints",
    "check": "pnpm check:types",
    "check:types": "tsc -b tsconfig.json",
    "check:tsgo": "tsgo -b tsconfig.json",
    "check:all": "pnpm check:tsgo && pnpm check:pre-commit",
    "check:pre-commit": "pnpm lint && pnpm dead-code && pnpm check && pnpm test --run",
    "lint": "oxlint && dprint check",
    "lint-fix": "oxlint --fix && dprint fmt",
    "test": "vitest",
    "test:browser": "pnpm --filter @lucas-barake/effect-local-browser test:browser",
    "coverage": "vitest --coverage",
    "codegen": "node scripts/codegen.mjs",
    "docgen": "tsc -b tsconfig.json",
    "changeset-version": "changeset version",
    "changeset-publish": "pnpm build && changeset publish"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "dprint",
      "esbuild"
    ]
  },
  "devDependencies": {
    "@automerge/automerge": "3.3.2",
    "@changesets/changelog-github": "^0.7.0",
    "@changesets/cli": "^2.31.0",
    "@effect/language-service": "^0.85.1",
    "@effect/vitest": "4.0.0-beta.99",
    "@types/node": "^25.7.0",
    "@typescript/native-preview": "7.0.0-dev.20260420.1",
    "@vitest/coverage-v8": "4.1.10",
    "dprint": "^0.55.1",
    "effect": "4.0.0-beta.99",
    "glob": "^13.0.6",
    "knip": "6.27.0",
    "madge": "^8.0.0",
    "oxlint": "1.42.0",
    "typescript": "^6.0.3",
    "vitest": "4.1.10"
  }
}
