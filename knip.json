{
  "$schema": "https://unpkg.com/knip@6.27.0/schema.json",
  "includeEntryExports": false,
  "workspaces": {
    "packages/local-rpc": {
      "ignore": ["bench/PeerRpcServerPerformance.bench.ts", "bench/vitest.admission.config.ts"]
    },
    "packages/local-browser": {
      "entry": [
        "test-browser/*/src/*.{ts,tsx}",
        "test-browser/*/tests/*.spec.ts",
        "test-browser/*/vite.config.ts",
        "test-browser/*/public/service-worker.js"
      ],
      "ignoreDependencies": ["@effect/platform-browser"]
    }
  }
}
